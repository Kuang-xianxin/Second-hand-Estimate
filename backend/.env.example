# 大模型 API Keys（填你自己的）
DEEPSEEK_API_KEY=your_deepseek_key_here
QWEN_API_KEY=your_qwen_key_here
DOUBAO_API_KEY=your_doubao_key_here
ADMIN_TOKEN=

# 大模型名称（可按需切换）
DEEPSEEK_MODEL=deepseek-chat
QWEN_MODEL=qwen-max
DOUBAO_MODEL=ep-m-20260327193150-m6442

# 大模型接口配置（一般默认即可）
DEEPSEEK_BASE_URL=https://api.deepseek.com
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_TIMEOUT_SECONDS=30

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./guessr.db

# 服务配置
COOKIE_FILE=xianyu_cookies.txt
STORAGE_STATE_FILE=xianyu_storage_state.json
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173

# 爬虫配置
CRAWL_INTERVAL_SECONDS=300
MAX_ITEMS_PER_QUERY=60

# 捡漏阈值（元）
BARGAIN_THRESHOLD=120
